---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featured, ...rest] = posts;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="site-container">
			<Header />

			<main>
				<!-- Page header row -->
				<div class="blog-page-header box">
					<h1>Blog</h1>
					<p>Thoughts, essays & notes.</p>
				</div>

				<!-- Featured post (first/newest) -->
				{featured && (
					<a href={`/blog/${featured.id}/`} class="featured-post">
						{featured.data.heroImage && (
							<div class="featured-image">
								<Image width={900} height={400} src={featured.data.heroImage} alt="" />
							</div>
						)}
						<div class="featured-text box">
							<p class="post-date"><FormattedDate date={featured.data.pubDate} /></p>
							<h2>{featured.data.title}</h2>
							{featured.data.description && <p class="post-desc">{featured.data.description}</p>}
							<span class="read-more">Read article →</span>
						</div>
					</a>
				)}

				<!-- Remaining posts grid -->
				{rest.length > 0 && (
					<div class="posts-grid">
						{rest.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-card box">
								{post.data.heroImage && (
									<div class="post-card-image">
										<Image width={400} height={200} src={post.data.heroImage} alt="" />
									</div>
								)}
								<div class="post-card-body">
									<p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
									<h3>{post.data.title}</h3>
									{post.data.description && <p class="post-desc">{post.data.description}</p>}
								</div>
							</a>
						))}
					</div>
				)}
			</main>

			<Footer />
		</div>
	</body>
</html>

<style>
	main {
		width: 100%;
		margin: 0;
		padding: 0;
	}

	/* ── Page Header ──────────────────────── */
	.blog-page-header {
		border-bottom: 1px solid var(--border-color);
	}

	.blog-page-header h1 {
		margin: 0 0 0.25rem 0;
		font-size: 2rem;
		color: #fff;
	}

	.blog-page-header p {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	/* ── Featured post ────────────────────── */
	.featured-post {
		display: grid;
		grid-template-columns: 1fr 1fr;
		text-decoration: none;
		border-bottom: 1px solid var(--border-color);
		transition: background 0.2s ease;
	}

	.featured-post:hover {
		background-color: #1a1a1a;
	}

	.featured-image {
		overflow: hidden;
	}

	.featured-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
		transition: transform 0.3s ease;
	}

	.featured-post:hover .featured-image img {
		transform: scale(1.03);
	}

	.featured-text {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.5rem;
	}

	.featured-text h2 {
		font-size: 1.8rem;
		color: #fff;
		margin: 0;
		line-height: 1.2;
	}

	/* ── Post cards grid ──────────────────── */
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		border-top: 1px solid var(--border-color);
	}

	.post-card {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		border-right: 1px solid var(--border-color);
		border-bottom: 1px solid var(--border-color);
		transition: background 0.2s ease;
		padding: 0;
	}

	.post-card:nth-child(even) {
		border-right: none;
	}

	.post-card:hover {
		background-color: #1a1a1a;
	}

	.post-card-image img {
		width: 100%;
		height: 200px;
		object-fit: cover;
		border-radius: 0;
		display: block;
		transition: opacity 0.2s ease;
	}

	.post-card:hover .post-card-image img {
		opacity: 0.85;
	}

	.post-card-body {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		flex: 1;
	}

	.post-card-body h3 {
		font-size: 1.1rem;
		color: #fff;
		margin: 0;
		line-height: 1.3;
	}

	/* ── Shared ───────────────────────────── */
	.post-date {
		font-size: 0.78rem;
		color: var(--accent);
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-weight: 600;
	}

	.post-desc {
		font-size: 0.88rem;
		color: rgb(var(--gray));
		margin: 0;
		line-height: 1.5;
	}

	.read-more {
		display: inline-block;
		margin-top: 0.75rem;
		font-size: 0.85rem;
		color: var(--accent);
		font-weight: 600;
		letter-spacing: 0.04em;
	}

	/* ── Responsive ───────────────────────── */
	@media (max-width: 800px) {
		.featured-post {
			grid-template-columns: 1fr;
		}

		.posts-grid {
			grid-template-columns: 1fr;
		}

		.post-card {
			border-right: none;
		}
	}
</style>
